# Feature Checker Configuration
# Copy this file to .env and fill in your values

# ============================================================
# BROWSER SETTINGS
# ============================================================
CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
CHROME_DEBUG_PORT=9222

# ============================================================
# QBO CREDENTIALS (Example Product)
# ============================================================
QBO_EMAIL=your-email@domain.com
QBO_PASSWORD=your-password
QBO_TOTP_SECRET=YOUR_TOTP_SECRET_HERE

# ============================================================
# OUTPUT PATHS
# ============================================================
EVIDENCE_DIR=./output/evidence
REPORTS_DIR=./output/reports

# ============================================================
# ALERTING (Optional)
# ============================================================

# Slack
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=#demo-health

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL=

# ============================================================
# GENERAL
# ============================================================
LOG_LEVEL=INFO
SCREENSHOT_QUALITY=95
